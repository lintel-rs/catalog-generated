{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/httparchive/_shared/latest--page.json",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/ahmadnassri/har-schema/master/lib/page.json",
    "sourceSha256": "ceddea2aab6f37ae47947999dfe2a53836c8d9f33cc4ac14901c0b34926cab80"
  },
  "type": "object",
  "properties": {
    "startedDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(\\d{4})(-)?(\\d\\d)(-)?(\\d\\d)(T)?(\\d\\d)(:)?(\\d\\d)(:)?(\\d\\d)(\\.\\d+)?(Z|([+-])(\\d\\d)(:)?(\\d\\d))"
    },
    "id": {
      "type": "string",
      "unique": true
    },
    "title": {
      "type": "string"
    },
    "pageTimings": {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/httparchive/_shared/latest--pageTimings.json#"
    },
    "comment": {
      "type": "string"
    }
  },
  "optional": true,
  "required": [
    "startedDateTime",
    "id",
    "title",
    "pageTimings"
  ]
}
