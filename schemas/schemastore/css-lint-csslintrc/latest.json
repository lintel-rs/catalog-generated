{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/css-lint-csslintrc/latest.json",
  "title": "JSON schema for CSS Lint configuration files",
  "x-lintel": {
    "source": "https://www.schemastore.org/csslintrc.json",
    "sourceSha256": "04310f3500b44e7dd13fc38aaef8c62c4aced5daa0d3370d03c906b3697200a0",
    "fileMatch": [
      ".csslintrc"
    ]
  },
  "type": "object",
  "properties": {
    "adjoining-classes": {
      "$ref": "#/$defs/rule"
    },
    "box-model": {
      "$ref": "#/$defs/rule"
    },
    "box-sizing": {
      "$ref": "#/$defs/rule"
    },
    "bulletproof-font-face": {
      "$ref": "#/$defs/rule"
    },
    "compatible-vendor-prefixes": {
      "$ref": "#/$defs/rule"
    },
    "display-property-grouping": {
      "$ref": "#/$defs/rule"
    },
    "duplicate-background-images": {
      "$ref": "#/$defs/rule"
    },
    "duplicate-properties": {
      "$ref": "#/$defs/rule"
    },
    "empty-rules": {
      "$ref": "#/$defs/rule"
    },
    "fallback-colors": {
      "$ref": "#/$defs/rule"
    },
    "floats": {
      "$ref": "#/$defs/rule"
    },
    "font-faces": {
      "$ref": "#/$defs/rule"
    },
    "font-sizes": {
      "$ref": "#/$defs/rule"
    },
    "gradients": {
      "$ref": "#/$defs/rule"
    },
    "ids": {
      "$ref": "#/$defs/rule"
    },
    "import": {
      "$ref": "#/$defs/rule"
    },
    "important": {
      "$ref": "#/$defs/rule"
    },
    "known-properties": {
      "$ref": "#/$defs/rule"
    },
    "outline-none": {
      "$ref": "#/$defs/rule"
    },
    "overqualified-elements": {
      "$ref": "#/$defs/rule"
    },
    "qualified-headings": {
      "$ref": "#/$defs/rule"
    },
    "regex-selectors": {
      "$ref": "#/$defs/rule"
    },
    "shorthand": {
      "$ref": "#/$defs/rule"
    },
    "star-property-hack": {
      "$ref": "#/$defs/rule"
    },
    "text-indent": {
      "$ref": "#/$defs/rule"
    },
    "underscore-property-hack": {
      "$ref": "#/$defs/rule"
    },
    "unique-headings": {
      "$ref": "#/$defs/rule"
    },
    "universal-selector": {
      "$ref": "#/$defs/rule"
    },
    "unqualified-attributes": {
      "$ref": "#/$defs/rule"
    },
    "vendor-prefix": {
      "$ref": "#/$defs/rule"
    },
    "zero-units": {
      "$ref": "#/$defs/rule"
    }
  },
  "id": "https://json.schemastore.org/csslintrc.json",
  "$defs": {
    "rule": {
      "description": "CSS Lint rule\n\n'false' means rule is off\n'true' means it is a warning\n'2' means the rule is an error",
      "enum": [
        2,
        true,
        false
      ]
    }
  }
}
