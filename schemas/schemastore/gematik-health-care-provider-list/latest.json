{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/gematik-health-care-provider-list/latest.json",
  "title": "HCPsRepository",
  "description": "List of all hcps",
  "x-lintel": {
    "source": "https://www.schemastore.org/gematik-test-hcps.json",
    "sourceSha256": "4bd354136ab0de3576c338efe324bd9b7b57ddd3f7d27204927846fd2b02ce53",
    "fileMatch": [
      "**/testdata/hcp/hcp.yml",
      "**/testdata/hcp/hcp.yaml"
    ],
    "parsers": [
      "yaml"
    ]
  },
  "type": "object",
  "properties": {
    "hcps": {
      "type": "object",
      "existingJavaType": "java.util.Map<String, Hcp>",
      "additionalProperties": {
        "$ref": "#/$defs/Hcp",
        "type": "object"
      }
    }
  },
  "$defs": {
    "Hcp": {
      "title": "HCP",
      "description": "An HCP",
      "type": "object",
      "required": [
        "hcpData",
        "cards"
      ],
      "properties": {
        "hcpData": {
          "type": "object",
          "required": [
            "name",
            "telematik-id",
            "hcpi",
            "hcpRole"
          ],
          "properties": {
            "name": {
              "type": "object",
              "required": [
                "given",
                "last"
              ],
              "properties": {
                "title": {
                  "type": "string"
                },
                "given": {
                  "type": "string"
                },
                "last": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "telematik-id": {
              "type": "string"
            },
            "hcpi": {
              "type": "string"
            },
            "hcpRole": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "ownerTestsuite": {
          "type": "string"
        },
        "cards": {
          "type": "array",
          "items": {
            "$ref": "https://catalog.lintel.tools/schemas/schemastore/gematik-health-care-provider-list/_shared/latest--gematik-test-patients.json#/$defs/Card",
            "type": "object"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
