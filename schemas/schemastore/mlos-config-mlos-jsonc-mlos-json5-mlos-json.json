{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/mlos-config-mlos-jsonc-mlos-json5-mlos-json.json",
  "title": "mlos_bench config schema",
  "description": "Any mlos_bench config - this is the top level schema that should be used to validate any mlos_bench config",
  "if": {
    "$comment": "check if the config has a class or services property",
    "type": "object",
    "properties": {
      "class": {
        "type": "string"
      },
      "services": {
        "type": "array"
      }
    },
    "oneOf": [
      {
        "required": [
          "class"
        ]
      },
      {
        "properties": {
          "$schema": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "services": {
            "type": "array"
          }
        },
        "unevaluatedProperties": false,
        "required": [
          "services"
        ]
      }
    ]
  },
  "then": {
    "oneOf": [
      {
        "description": "environment config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--environment-schema.json"
      },
      {
        "description": "optimizer config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--optimizer-schema.json"
      },
      {
        "description": "scheduler config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--scheduler-schema.json"
      },
      {
        "description": "service config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--service-schema.json"
      },
      {
        "description": "storage config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--storage-schema.json"
      }
    ]
  },
  "else": {
    "$comment": "these configs are *mostly* flat dicts",
    "anyOf": [
      {
        "description": "cli config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--cli-schema.json"
      },
      {
        "description": "globals config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--globals-schema.json"
      },
      {
        "description": "tunables params config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--tunable-params-schema.json"
      },
      {
        "description": "tunables values config",
        "type": "object",
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--tunable-values-schema.json"
      }
    ]
  }
}
