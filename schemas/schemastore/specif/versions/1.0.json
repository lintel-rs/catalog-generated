            "type": "string"
          },
          "properties": {
            "$ref": "#/$defs/properties"
          },
          "revision": {
            "$ref": "#/$defs/revision"
          },
          "replaces": {
            "$ref": "#/$defs/replaces"
          },
          "alternativeIds": {
            "$ref": "#/$defs/alternativeIds"
          },
          "changedAt": {
            "$ref": "#/$defs/dateTime"
          },
          "changedBy": {
            "type": "string"
          },
