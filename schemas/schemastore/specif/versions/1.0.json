      }
    },
    "statementClasses": {
      "description": "The class definitions for statements in subject-predicate-object statements, where subject and object are resources.",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "$ref": "#/$defs/id"
          },
          "title": {
            "$ref": "#/$defs/value"
          },
          "description": {
            "$ref": "#/$defs/value"
          },
          "extends": {
