{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/custom-machinery-machine.json",
  "allOf": [
    {
      "if": {
        "required": [
          "name"
        ]
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/custom-machinery-machine--machine.json"
      }
    },
    {
      "if": {
        "required": [
          "parent"
        ]
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/custom-machinery-machine--upgraded_machine.json"
      }
    }
  ]
}
