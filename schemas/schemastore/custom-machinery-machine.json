{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://alec016.github.io/Custom-Machinery/Json%20Schema/src/main/resources/schemas/custom_machinery_machine.json",
  "allOf": [
    {
      "if": {
        "required": [
          "name"
        ]
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/machine.json"
      }
    },
    {
      "if": {
        "required": [
          "parent"
        ]
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/upgraded_machine.json"
      }
    }
  ]
}
