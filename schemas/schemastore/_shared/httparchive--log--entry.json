{
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/httparchive--log--entry.json",
  "$schema": "http://json-schema.org/draft-06/schema#",
  "type": "object",
  "optional": true,
  "required": [
    "startedDateTime",
    "time",
    "request",
    "response",
    "cache",
    "timings"
  ],
  "properties": {
    "pageref": {
      "type": "string"
    },
    "startedDateTime": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(\\d{4})(-)?(\\d\\d)(-)?(\\d\\d)(T)?(\\d\\d)(:)?(\\d\\d)(:)?(\\d\\d)(\\.\\d+)?(Z|([+-])(\\d\\d)(:)?(\\d\\d))"
    },
    "time": {
      "type": "number",
      "min": 0
    },
    "request": {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/httparchive--log--entry--request.json#"
    },
    "response": {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/httparchive--log--entry--response.json#"
    },
    "cache": {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/httparchive--log--entry--cache.json#"
    },
    "timings": {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/httparchive--log--entry--timings.json#"
    },
    "serverIPAddress": {
      "type": "string",
      "oneOf": [
        {
          "format": "ipv4"
        },
        {
          "format": "ipv6"
        }
      ]
    },
    "connection": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    }
  }
}
