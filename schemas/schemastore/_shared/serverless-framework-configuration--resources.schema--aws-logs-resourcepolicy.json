{
  "typeName": "AWS::Logs::ResourcePolicy",
  "description": "The resource schema for AWSLogs ResourcePolicy. Source:- https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-logs.git",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-logs.git",
  "properties": {
    "PolicyName": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^([^:*\\/]+\\/?)*[^:*\\/]+$",
          "minLength": 1,
          "maxLength": 255
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "A name for resource policy"
    },
    "PolicyDocument": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "[\\u0009\\u000A\\u000D\\u0020-\\u00FF]+",
          "minLength": 1,
          "maxLength": 5120
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The policy document"
    }
  },
  "additionalProperties": false,
  "taggable": false,
  "primaryIdentifier": [
    "/properties/PolicyName"
  ],
  "createOnlyProperties": [
    "/properties/PolicyName"
  ],
  "required": [
    "PolicyName",
    "PolicyDocument"
  ],
  "title": "AWSLogsResourcePolicyProperties",
  "type": "object",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--resources.schema--aws-logs-resourcepolicy.json"
}
