{
  "typeName": "MongoDB::Atlas::Auditing",
  "description": "Returns and edits database auditing settings for MongoDB Cloud projects.. Source:- https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "properties": {
    "Profile": {
      "oneOf": [
        {
          "type": "string",
          "default": "default"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Profile used to provide credentials information, (a secret with the cfn/atlas/profile/{Profile}, is required), if not provided default is used"
    },
    "ProjectId": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 24,
          "minLength": 24,
          "pattern": "^([a-f0-9]{24})$"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Unique 24-hexadecimal digit string that identifies your project."
    }
  },
  "additionalProperties": false,
  "readOnlyProperties": [
    "/properties/AuditFilter",
    "/properties/ConfigurationType",
    "/properties/AuditAuthorizationSuccess"
  ],
  "required": [
    "ProjectId"
  ],
  "primaryIdentifier": [
    "/properties/ProjectId",
    "/properties/Profile"
  ],
  "createOnlyProperties": [
    "/properties/ProjectId",
    "/properties/Profile"
  ],
  "title": "MongoDBAtlasAuditingProperties",
  "type": "object",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--resources.schema--mongodb-atlas-auditing.json"
}
