{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/use.schema-8.json",
  "title": "schema for psql job usage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pgSecretRefName",
    "sqlFile"
  ],
  "properties": {
    "pgSecretRefName": {
      "description": "Secret with Postgresql credentials to execute the script",
      "type": "string"
    },
    "sqlFile": {
      "description": "Path to .sql file in the repo",
      "examples": [
        "./scripts/restore.sql"
      ],
      "type": "string"
    }
  }
}
