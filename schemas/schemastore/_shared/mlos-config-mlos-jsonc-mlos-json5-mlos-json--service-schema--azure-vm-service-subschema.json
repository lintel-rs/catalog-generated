{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--service-schema--azure-vm-service-subschema.json",
  "title": "mlos_bench Azure VM Service config",
  "description": "config for an mlos_bench Azure VM Service",
  "type": "object",
  "properties": {
    "class": {
      "enum": [
        "mlos_bench.services.remote.azure.AzureVMService",
        "mlos_bench.services.remote.azure.azure_vm_services.AzureVMService"
      ]
    },
    "config": {
      "type": "object",
      "allOf": [
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--service-schema--azure-network-service-subschema--azure-deployment-service-subschema.json#/$defs/azure_deployment_service_config"
        },
        {
          "properties": {
            "customDataFile": {
              "description": "Path to a custom data file whose contents should be base64 encoded and passed to the VM template as customDataBase64 in the template parameters.",
              "type": "string",
              "examples": [
                "customData.txt",
                "cloud-init.config.yml",
                "cloud-init.script.sh"
              ]
            }
          }
        }
      ],
      "unevaluatedProperties": false
    }
  },
  "required": [
    "class"
  ]
}
