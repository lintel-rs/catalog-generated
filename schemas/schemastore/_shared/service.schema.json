{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/service.schema.json",
  "description": "Schema for service entities",
  "examples": [],
  "allOf": [
    {
      "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/entity.schema.json"
    },
    {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apiVersion": {
          "enum": [
            "v3"
          ]
        },
        "kind": {
          "enum": [
            "service"
          ]
        },
        "metadata": {
          "type": "object"
        },
        "extensions": {
          "type": "object"
        },
        "spec": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "lifecycle": {
              "type": "string",
              "description": "The lifecycle state of the component.",
              "examples": [
                "experimental",
                "production",
                "deprecated"
              ],
              "minLength": 1
            },
            "tier": {
              "type": "string",
              "description": "The importance of the component",
              "examples": [
                "1",
                "High"
              ],
              "minLength": 1
            },
            "type": {
              "description": "The type of service",
              "examples": [
                "web",
                "grpc",
                "http",
                "rest",
                "graphql"
              ],
              "type": "string"
            },
            "languages": {
              "description": "The service's programming language. See examples for a list of recognizable languages",
              "examples": [
                [
                  "dotnet",
                  "go",
                  "java",
                  "js",
                  "php",
                  "python",
                  "ruby",
                  "c++"
                ]
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "dependsOn": {
              "description": "A list of components the service depends on",
              "examples": [
                "service:myapp",
                "queue:myqueue",
                "datastore:mydatastore",
                "library:mylibrary"
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "componentOf": {
              "description": "A list of components the service is a part of",
              "examples": [
                "system:my-example-system",
                "service:myapp"
              ],
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "integrations": {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/integrations.schema.json"
        },
        "datadog": {
          "type": "object",
          "description": "Datadog product integrations for the service entity",
          "additionalProperties": false,
          "properties": {
            "pipelines": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/datadog_pipelines.schema.json"
            },
            "events": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/datadog_events.schema.json"
            },
            "logs": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/datadog_logs.schema.json"
            },
            "codeLocations": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/datadog_code_locations.schema.json"
            }
          }
        }
      }
    }
  ]
}
