{
  "typeName": "AWS::Personalize::Schema",
  "description": "Resource schema for AWS::Personalize::Schema.. Source:- https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-personalize",
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-personalize",
  "properties": {
    "Name": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 63,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9\\-_]*"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Name for the schema."
    },
    "Schema": {
      "oneOf": [
        {
          "type": "string",
          "maxLength": 10000
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "A schema in Avro JSON format."
    },
    "Domain": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ECOMMERCE",
            "VIDEO_ON_DEMAND"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The domain of a Domain dataset group."
    }
  },
  "additionalProperties": false,
  "required": [
    "Name",
    "Schema"
  ],
  "createOnlyProperties": [
    "/properties/Name",
    "/properties/Schema",
    "/properties/Domain"
  ],
  "readOnlyProperties": [
    "/properties/SchemaArn"
  ],
  "primaryIdentifier": [
    "/properties/SchemaArn"
  ],
  "title": "AWSPersonalizeSchemaProperties",
  "type": "object",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/serverless-framework-configuration--resources.schema--aws-personalize-schema.json"
}
