{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/_shared/kontinuous-values-yaml--kontinuous.values.schema-3--use.schema-2.json",
  "title": "schema for seed-db job usage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "seedPath"
  ],
  "properties": {
    "pgSecretName": {
      "description": "Secret with Postgresql credentials to execute the script",
