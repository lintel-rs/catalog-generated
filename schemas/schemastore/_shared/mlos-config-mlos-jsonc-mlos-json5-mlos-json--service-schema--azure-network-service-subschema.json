    "config": {
      "type": "object",
      "allOf": [
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/mlos-config-mlos-jsonc-mlos-json5-mlos-json--service-schema--azure-vm-service-subschema--azure-deployment-service-subschema.json#/$defs/azure_deployment_service_config"
        },
        {
          "$comment": "Unlike VM service, which can still do remote exec, network service needs a deployment template.",
