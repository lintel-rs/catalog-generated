{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/openapi-json.json",
  "title": "OpenAPI Document v3.X",
  "type": "object",
  "required": [
    "openapi"
  ],
  "properties": {
    "openapi": {
      "pattern": "^3\\.[0-2]\\.",
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "openapi": {
            "pattern": "^3\\.0\\.",
            "type": "string"
          }
        }
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/2024-10-18"
      }
    },
    {
      "if": {
        "properties": {
          "openapi": {
            "pattern": "^3\\.1\\.",
            "type": "string"
          }
        }
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/2025-09-15"
      }
    },
    {
      "if": {
        "properties": {
          "openapi": {
            "pattern": "^3\\.2\\.",
            "type": "string"
          }
        }
      },
      "then": {
        "$ref": "https://catalog.lintel.tools/schemas/schemastore/_shared/2025-09-17"
      }
    }
  ]
}
