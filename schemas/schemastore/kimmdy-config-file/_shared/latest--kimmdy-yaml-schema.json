{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/kimmdy-config-file/_shared/latest--kimmdy-yaml-schema.json",
  "description": "Settings for naive HAT reaction",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/graeter-group/kimmdy-reactions/main/src/hat_naive/kimmdy-yaml-schema.json",
    "sourceSha256": "2b5573ad148b9ba7eb3886d348580866f07838fe6c46986de57113ea96e9e2ff"
  },
