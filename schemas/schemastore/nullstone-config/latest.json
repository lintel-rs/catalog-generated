{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/nullstone-config/versions/0.1.json",
  "title": "Nullstone configuration specification",
  "description": "The Nullstone configuration file is a YAML file defining a platform-agnostic architecture",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/nullstone-io/iac/master/.schema/config.0.1.json",
    "sourceSha256": "74d314e2169a8e7957e0965415adab505a4bf58a061a967c270d07829e4b99d5"
  },
  "type": "object",
  "properties": {
    "version": {
      "const": "0.1"
    },
    "apps": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/app"
        }
      },
      "additionalProperties": false
    },
    "blocks": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/block"
        }
      },
      "additionalProperties": false
    },
    "cluster_namespaces": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/cluster_namespace"
        }
      },
      "additionalProperties": false
    },
    "clusters": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/cluster"
        }
      },
      "additionalProperties": false
    },
    "datastores": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/datastore"
        }
      },
      "additionalProperties": false
    },
    "domains": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/domain"
        }
      },
      "additionalProperties": false
    },
    "ingresses": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/ingress"
        }
      },
      "additionalProperties": false
    },
    "networks": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/network"
        }
      },
      "additionalProperties": false
    },
    "subdomains": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9\\-]+$": {
          "$ref": "#/$defs/subdomain"
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "version"
  ],
  "$defs": {
    "block": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "module": {
          "type": "string",
          "description": ""
        },
        "module_version": {
          "type": "string",
          "description": ""
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        },
        "is_shared": {
          "type": "boolean",
          "description": ""
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "app": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "module": {
          "type": "string",
          "description": ""
        },
        "module_version": {
          "type": "string",
          "description": ""
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        },
        "is_shared": {
          "type": "boolean",
          "description": ""
        },
        "framework": {
          "type": "string",
          "description": ""
        },
        "environment": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z0-9_]+$": {
              "type": "string"
            }
          }
        },
        "capabilities": {
          "oneOf": [
            {
              "$ref": "#/$defs/capabilities"
            },
            {
              "$ref": "#/$defs/capabilitiesArray"
            }
          ]
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "cluster_namespace": {
      "allOf": [
        {
          "$ref": "#/$defs/block"
        }
      ]
    },
    "cluster": {
      "allOf": [
        {
          "$ref": "#/$defs/block"
        }
      ]
    },
    "datastore": {
      "allOf": [
        {
          "$ref": "#/$defs/block"
        }
      ]
    },
    "domain": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "module": {
          "type": "string",
          "description": ""
        },
        "module_version": {
          "type": "string",
          "description": ""
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        },
        "dns": {
          "$ref": "#/$defs/domain_dns"
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "domain_dns": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "template": {
          "type": "string",
          "description": "A templated string for configuration the domain name. This interpolates {{ NULLSTONE_ORG }}"
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "ingress": {
      "allOf": [
        {
          "$ref": "#/$defs/block"
        }
      ]
    },
    "network": {
      "allOf": [
        {
          "$ref": "#/$defs/block"
        }
      ]
    },
    "subdomain": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "module": {
          "type": "string",
          "description": ""
        },
        "module_version": {
          "type": "string",
          "description": ""
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        },
        "is_shared": {
          "type": "boolean",
          "description": ""
        },
        "dns": {
          "$ref": "#/$defs/subdomain_dns"
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "subdomain_dns": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "template": {
          "type": "string",
          "description": "A templated string for configuration the subdomain name. This interpolates {{ random() }}, {{ NULLSTONE_ORG }}, {{ NULLSTONE_STACK }}, {{ NULLSTONE_ENV }}"
        }
      },
      "patternProperties": {
        "^x-": {}
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/capability"
      }
    },
    "capabilitiesArray": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/namedCapability"
      }
    },
    "capability": {
      "type": "object",
      "properties": {
        "namespace": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "module_version": {
          "type": "string"
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        }
      }
    },
    "namedCapability": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "namespace": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "module_version": {
          "type": "string"
        },
        "vars": {
          "$ref": "#/$defs/variables"
        },
        "connections": {
          "$ref": "#/$defs/connection_targets"
        }
      }
    },
    "variables": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z_][A-Za-z0-9_\\-]*$": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string"
            },
            {
              "type": "integer"
            },
            {
              "type": "number"
            },
            {
              "type": "object"
            },
            {
              "type": "array"
            }
          ]
        }
      }
    },
    "connection_targets": {
      "type": "object",
      "patternProperties": {
        "^[_a-z0-9\\-]+$": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(?:([a-zA-Z0-9\\-]+)\\.)?(?:([a-zA-Z0-9\\-]+)\\.)?([a-zA-Z0-9\\-]+)$"
            },
            {
              "$ref": "#/$defs/connection_target"
            }
          ]
        }
      }
    },
    "connection_target": {
      "type": "object",
      "properties": {
        "stack_name": {
          "type": "string"
        },
        "env_name": {
          "type": "string"
        },
        "block_name": {
          "type": "string"
        }
      },
      "required": [
        "block_name"
      ]
    }
  },
  "additionalProperties": false
}
