{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/runny/latest.json",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/simonwhitaker/runny/main/schema/runny.schema.json",
    "sourceSha256": "65a6a79f5179e6c53e6a325856a3a4dc3b04cc3d5aaa17f0948e974cd3c1d6fa",
    "fileMatch": [
      ".runny.yaml",
      ".runny.yml"
    ],
    "parsers": [
      "yaml"
    ]
  },
  "$defs": {
    "CommandDef": {
      "type": "object",
      "properties": {
        "argnames": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "if": {
          "type": "string"
        },
        "internal": {
          "type": "boolean"
        },
        "needs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "run": {
          "type": "string"
        },
        "shell": {
          "type": "string"
        },
        "then": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "additionalProperties": false
    },
    "Config": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/CommandDef"
          }
        },
        "env": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "shell": {
          "type": "string"
        }
      },
      "required": [
        "commands"
      ],
      "additionalProperties": false
    }
  },
  "$ref": "#/$defs/Config"
}
