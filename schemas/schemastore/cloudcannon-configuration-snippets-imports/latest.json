    "SnippetImportExclude": {
      "type": "array",
      "items": {
        "type": "string",
        "documented": true,
        "title": "exclude[*]"
      },
      "description": "This key defines the list of excluded snippets.\n\nIf unset, all snippets are excluded unless defined in `include`.",
