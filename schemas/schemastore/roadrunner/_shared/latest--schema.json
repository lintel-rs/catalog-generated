{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json",
  "title": "roadrunner-memory",
  "description": "The schema contains all the valid configuration parameters for the Memory plugin for the roadrunner job system.",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/roadrunner-server/memory/refs/heads/master/schema.json",
    "sourceSha256": "c4690b6d3b5d9ee89a19d2ba9cc9a448d410bbb56309af0f332d07d835ca7f29"
  },
  "$defs": {
    "pipeline": {
      "type": "object",
      "required": [
        "driver"
      ],
      "additionalProperties": false,
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "memory"
          ]
        },
        "config": {
          "type": "object",
          "description": "Configuration options for the Memory pipeline.",
          "additionalProperties": false,
          "properties": {
            "priority": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json#/$defs/PipelineProperties/priority"
            },
            "prefetch": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json#/$defs/PipelineProperties/prefetch"
            }
          }
        }
      }
    }
  }
}
