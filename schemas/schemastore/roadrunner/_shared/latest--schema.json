{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json",
  "title": "roadrunner-boltdb",
  "description": "The schema contains all the valid configuration parameters for the BoltDB plugin for the roadrunner job system.",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/roadrunner-server/boltdb/refs/heads/master/schema.json",
    "sourceSha256": "918820e58d84e386c17c7251ff4109619ff84bd051c35c93f95984d40e1fee58"
  },
  "$defs": {
    "permissions": {
      "description": "Permissions for the BoltDB database file, if created by RR.",
      "type": "integer",
      "default": 755,
      "minimum": 0,
      "maximum": 777
    },
    "file": {
      "description": "BoltDB database file to create or use.",
      "type": "string",
      "default": "rr.db"
    },
    "pipeline": {
      "type": "object",
      "required": [
        "driver"
      ],
      "properties": {
        "driver": {
          "type": "string",
          "enum": [
            "boltdb"
          ]
        },
        "config": {
          "type": "object",
          "description": "Configuration for the BoltDB pipeline.",
          "properties": {
            "priority": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json#/$defs/PipelineProperties/priority"
            },
            "prefetch": {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/roadrunner/_shared/latest--schema.json#/$defs/PipelineProperties/prefetch"
            },
            "permissions": {
              "$ref": "#/$defs/permissions"
            },
            "file": {
              "$ref": "#/$defs/file"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "driver": {
      "type": "object",
      "properties": {
        "file": {
          "$ref": "#/$defs/file"
        },
        "permissions": {
          "$ref": "#/$defs/permissions"
        },
        "interval": {
          "description": "TTL keys check interval in seconds. It's safe to use 1 second here, but can be a little costly to performance. If you set this to zero, 60 will be used.",
          "type": "integer",
          "minimum": 1,
          "default": 60
        }
      },
      "description": "Configuration options for the BoltDB driver.",
      "additionalProperties": false
    }
  }
}
