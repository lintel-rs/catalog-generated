          }
        },
        "node": {
          "$ref": "#/$defs/node"
        },
        "concurrency": {
          "$ref": "#/$defs/concurrency"
        },
        "kind": {},
        "name": {},
        "platform": {},
        "workspace": {},
        "clone": {},
        "trigger": {},
        "depends_on": {}
      }
    },
    "pipeline_ssh": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "server"
