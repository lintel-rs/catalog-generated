            },
            "user": {
              "$ref": "#/$defs/stringOrSecret"
            },
            "password": {
              "$ref": "#/$defs/stringOrSecret"
            },
            "ssh_key": {
              "$ref": "#/$defs/stringOrSecret"
            }
          },
          "type": "object"
        },
        "concurrency": {
          "$ref": "#/$defs/concurrency"
        },
        "kind": {},
        "name": {},
        "platform": {},
        "workspace": {},
        "clone": {},
        "trigger": {},
        "depends_on": {}
      }
