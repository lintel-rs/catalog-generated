{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/minecraft-data-pack-tag/latest.json",
  "title": "Minecraft Data Pack Tag",
  "description": "A tag's for a Minecraft data pack config schema",
  "x-lintel": {
    "source": "https://www.schemastore.org/minecraft-tag.json",
    "sourceSha256": "2f29564f92b15619ac29baec4dbc65767003ef1ab2c52faa0f4cffd21bafb50c"
  },
  "type": "object",
  "properties": {
    "replace": {
      "type": "boolean",
      "default": false
    },
    "values": {
      "description": "Values",
      "type": "array",
      "items": {
        "oneOf": [
          {
            "anyOf": [
              {
                "type": "string",
                "pattern": "^[a-z0-9_.-]+:[a-z0-9_.-]+"
              },
              {
                "type": "string",
                "pattern": "^#[a-z0-9_.-]+:[a-z0-9_.-]+"
              }
            ]
          },
          {
            "type": "object",
            "properties": {
              "id": {
                "anyOf": [
                  {
                    "description": "An identifier for the current data pack",
                    "type": "string",
                    "pattern": "^[a-z0-9_.-]+:[a-z0-9_.-]+"
                  },
                  {
                    "description": "An identifier for the current data pack",
                    "type": "string",
                    "pattern": "^#[a-z0-9_.-]+:[a-z0-9_.-]+"
                  }
                ]
              },
              "required": {
                "description": "Whether it's required for the current data pack",
                "type": "boolean"
              }
            }
          }
        ]
      }
    }
  },
  "$comment": "https://minecraft.wiki/w/Data_Pack",
  "required": [
    "values"
  ]
}
