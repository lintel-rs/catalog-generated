{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/cics-ts-region-tagging/_shared/latest--cicstags-1.0.0.json",
  "title": "CICS region tagging file JSON Schema.",
  "description": "Schema that describes the contents of a CICS region tagging file.",
  "x-lintel": {
    "source": "https://public.dhe.ibm.com/ibmdl/export/pub/software/htp/cics/schemas/json/cicstags/cicstags-1.0.0.json",
    "sourceSha256": "bf09b3cc4084708cce9f5b1ee2d30427f1e5f76e2dbab58b991773021c3de5cc"
  },
  "type": "object",
  "properties": {
    "schemaVersion": {
      "description": "Specify the tagging file schema version.",
      "type": "string",
      "enum": [
        "regionTagging/1.0.0",
        "regionTagging/1.0"
      ]
    },
    "regiontags": {
      "description": "CICS region tags.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "cicsts-RegionTypes": {
            "$ref": "#/$defs/region-tags"
          },
          "cicsts-RegionUsage": {
            "$ref": "#/$defs/code-level-tags"
          },
          "cicsts-Applications": {
            "$ref": "#/$defs/application-tags"
          },
          "cicsts-HealthCheckExcludedRegions": {
            "$ref": "#/$defs/excluded-region-tags"
          },
          "cicsts-ExcludedHealthChecks": {
            "$ref": "#/$defs/excluded-check-tags"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "copyright": [
    "*----------------------------------------------------------------*",
    "*  IBM Confidential                                              *",
    "*  PID 5655-YA1                                                  *",
    "*  Copyright IBM Corp. 2020, 2024                                *",
    "*  @{[**]copyright.years=2020, 2024}                             *",
    "*----------------------------------------------------------------*"
  ],
  "$defs": {
    "region-label": {
      "description": "Define tag and applids, region userids or jobnames for that tag.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Tag": {
            "type": "string",
            "pattern": "^[^ :]*$",
            "maxLength": 80
          },
          "APPLID": {
            "type": "string",
            "pattern": "^[A-Z0-9$@#*?]*$",
            "maxLength": 8
          },
          "RegionUserID": {
            "type": "string",
            "pattern": "^[A-Z0-9$@#*?]*$",
            "maxLength": 8
          },
          "Jobname": {
            "type": "string",
            "pattern": "^[A-Z0-9$@#*?]*$",
            "maxLength": 8
          }
        },
        "additionalProperties": false
      },
      "required": [
        "Tag"
      ]
    },
    "region-tags": {
      "description": "CICS region tags.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Unique": {
            "type": "string",
            "enum": [
              "Yes",
              "No"
            ]
          },
          "RegionTag": {
            "$ref": "#/$defs/region-label"
          }
        },
        "additionalProperties": false
      }
    },
    "code-level-tags": {
      "description": "Code level tags.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Unique": {
            "type": "string",
            "enum": [
              "Yes",
              "No"
            ]
          },
          "UsageTag": {
            "$ref": "#/$defs/region-label"
          }
        },
        "additionalProperties": false
      }
    },
    "application-tags": {
      "description": "Application tags.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Unique": {
            "type": "string",
            "enum": [
              "Yes",
              "No"
            ]
          },
          "AppTag": {
            "$ref": "#/$defs/region-label"
          }
        },
        "additionalProperties": false
      }
    },
    "excluded-region-tags": {
      "description": "Regions to be excluded from health checks.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "ExcludeUsage": {
            "type": "string",
            "maxLength": 80
          }
        },
        "additionalProperties": false
      }
    },
    "excluded-check-tags": {
      "description": "Specific health checks to be excluded.",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Check": {
            "type": "string",
            "maxLength": 80,
            "pattern": "^DFHH([0-9]{4}).*$"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
