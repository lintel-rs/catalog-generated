{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/minecraft-resource-pack-texture-mcmeta/latest.json",
  "title": "Minecraft Resource Pack Texture Mcmeta",
  "description": "A mcmeta file for an animated texture for a Minecraft resource pack config schema",
  "x-lintel": {
    "source": "https://www.schemastore.org/minecraft-texture-mcmeta.json",
    "sourceSha256": "41f5a7510f419943a451f81e4f7d7f41d2b26b4a448362bfea22a944e4e933c9",
    "fileMatch": [
      "**/assets/*/textures/**/*.png.mcmeta"
    ]
  },
  "type": "object",
  "oneOf": [
    {
      "properties": {
        "animation": {
          "description": "Animation",
          "type": "object",
          "properties": {
            "interpolate": {
              "type": "boolean",
              "default": false
            },
            "width": {
              "type": "integer"
            },
            "height": {
              "type": "integer"
            },
            "frametime": {
              "type": "integer",
              "default": 1
            },
            "frames": {
              "type": "array",
              "items": {
                "oneOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "object",
                    "properties": {
                      "index": {
                        "type": "integer"
                      },
                      "time": {
                        "type": "integer"
                      }
                    }
                  }
                ]
              }
            }
          }
        }
      },
      "required": [
        "animation"
      ],
      "type": "object"
    },
    {
      "properties": {
        "fusion": {
          "$comment": "Fusion properties for Minecraft texture metadata",
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/minecraft-resource-pack-texture-mcmeta/_shared/latest--partial-fusion-texture-metadata.json#/$defs/fusion-properties"
        }
      },
      "required": [
        "fusion"
      ],
      "type": "object"
    }
  ]
}
