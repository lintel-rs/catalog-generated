{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/knip/latest.json",
  "title": "Knip configuration for JSON",
  "description": "See <https://github.com/webpro-nl/knip>",
  "x-lintel": {
    "source": "https://unpkg.com/knip@5/schema.json",
    "sourceSha256": "3335ee2dccb4b8684635a4d384a1c2dbfdde9c3761f43e25c46898eb433bd9ce",
    "fileMatch": [
      "knip.json",
      ".knip.json",
      "knip.jsonc",
      ".knip.jsonc"
    ],
    "parsers": [
      "json",
      "jsonc"
    ]
  },
  "type": "object",
  "properties": {
    "ignoreBinaries": {
      "$ref": "#/$defs/ignoreBinaries"
    },
    "ignoreDependencies": {
      "$ref": "#/$defs/ignoreDependencies"
    },
    "ignoreFiles": {
      "$ref": "#/$defs/ignoreFiles"
    },
    "ignoreMembers": {
      "$ref": "#/$defs/ignoreMembers"
    },
    "ignoreUnresolved": {
      "$ref": "#/$defs/ignoreUnresolved"
    },
    "ignoreWorkspaces": {
      "title": "Workspaces to exclude from the report",
      "examples": [
        "packages/ignore-me"
      ],
      "$ref": "#/$defs/list"
    },
    "include": {
      "title": "Include issue types in the report",
      "examples": [
        "files",
        "dependencies"
      ],
      "$ref": "#/$defs/issueTypes"
    },
    "exclude": {
      "title": "Exclude issue types from the report",
      "examples": [
        "classMembers",
        "enumMembers"
      ],
      "$ref": "#/$defs/issueTypes"
    },
    "ignoreExportsUsedInFile": {
      "title": "Ignore exports used in file",
      "examples": [
        {
          "ignoreExportsUsedInFile": true
        },
        {
          "ignoreExportsUsedInFile": {
            "interface": true,
            "type": true
          }
        }
      ],
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "object",
          "properties": {
            "class": {
              "type": "boolean"
            },
            "enum": {
              "type": "boolean"
            },
            "function": {
              "type": "boolean"
            },
            "interface": {
              "type": "boolean"
            },
            "member": {
              "type": "boolean"
            },
            "type": {
              "type": "boolean"
            },
            "variable": {
              "type": "boolean"
            }
          }
        }
      ]
    },
    "ignoreIssues": {
      "title": " Ignore specific issue types for specific file patterns",
      "examples": [
        {
          "src/generated/**": [
            "exports",
            "types"
          ],
          "**/*.generated.ts": [
            "exports",
            "classMembers"
          ]
        }
      ],
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/issueTypes"
      }
    },
    "includeEntryExports": {
      "$ref": "#/$defs/includeEntryExports"
    },
    "tags": {
      "title": "Exclude (-) or include (+) exports with the specified JSDoc/TSDoc tags",
      "examples": [
        "+custom",
        "-lintignore",
        "-@internal"
      ],
      "$ref": "#/$defs/list"
    },
    "workspaces": {
      "title": "Configuration for workspaces",
      "type": "object",
      "additionalProperties": {
        "allOf": [
          {
            "$ref": "#/$defs/workspace"
          },
          {
            "$ref": "#/$defs/plugins"
          }
        ],
        "unevaluatedProperties": false
      }
    },
    "rules": {
      "type": "object",
      "properties": {
        "binaries": {
          "$ref": "#/$defs/ruleValue"
        },
        "catalog": {
          "$ref": "#/$defs/ruleValue"
        },
        "classMembers": {
          "$ref": "#/$defs/ruleValue"
        },
        "dependencies": {
          "$ref": "#/$defs/ruleValue"
        },
        "devDependencies": {
          "$ref": "#/$defs/ruleValue"
        },
        "optionalPeerDependencies": {
          "$ref": "#/$defs/ruleValue"
        },
        "duplicates": {
          "$ref": "#/$defs/ruleValue"
        },
        "enumMembers": {
          "$ref": "#/$defs/ruleValue"
        },
        "exports": {
          "$ref": "#/$defs/ruleValue"
        },
        "files": {
          "$ref": "#/$defs/ruleValue"
        },
        "nsExports": {
          "$ref": "#/$defs/ruleValue"
        },
        "nsTypes": {
          "$ref": "#/$defs/ruleValue"
        },
        "types": {
          "$ref": "#/$defs/ruleValue"
        },
        "unlisted": {
          "$ref": "#/$defs/ruleValue"
        },
        "unresolved": {
          "$ref": "#/$defs/ruleValue"
        }
      }
    },
    "treatConfigHintsAsErrors": {
      "title": "Exit with non-zero code (1) if there are any configuration hints",
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "$ref": "#/$defs/workspace"
    },
    {
      "$ref": "#/$defs/plugins"
    },
    {
      "properties": {
        "$schema": {
          "type": "string",
          "title": "JSON Schema",
          "description": "Pointer to the schema against which this document should be validated."
        }
      }
    }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ignoreBinaries": {
      "title": "Binaries to exclude from the report (regex allowed)",
      "examples": [
        "rm",
        "docker-compose",
        "curl"
      ],
      "$ref": "#/$defs/list"
    },
    "ignoreDependencies": {
      "title": "Dependencies to exclude from the report (regex allowed)",
      "examples": [
        "husky",
        "lint-staged"
      ],
      "$ref": "#/$defs/list"
    },
    "ignoreFiles": {
      "title": "Unused files to exclude from the report",
      "examples": [
        "husky",
        "lint-staged",
        "**/fixtures/**",
        "mocks/**"
      ],
      "default": [],
      "$ref": "#/$defs/globPatterns"
    },
    "ignoreUnresolved": {
      "title": "Unresolved imports to exclude from the report (regex allowed)",
      "examples": [
        "#/virtual"
      ],
      "$ref": "#/$defs/list"
    },
    "includeEntryExports": {
      "title": "Include entry files when reporting unused exports",
      "type": "boolean"
    },
    "ignoreMembers": {
      "title": "Class and enum members to exclude from the report (regex allowed)",
      "examples": [
        "render",
        "on.*"
      ],
      "$ref": "#/$defs/list"
    },
    "issueTypes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "files",
          "dependencies",
          "devDependencies",
          "optionalPeerDependencies",
          "unlisted",
          "binaries",
          "unresolved",
          "exports",
          "types",
          "nsExports",
          "nsTypes",
          "duplicates",
          "enumMembers",
          "classMembers",
          "catalog"
        ]
      }
    },
    "globPatterns": {
      "description": "Use file paths and glob patterns to match files. Knip uses fast-glob and picomatch (https://github.com/micromatch/picomatch)",
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "workspace": {
      "type": "object",
      "properties": {
        "entry": {
          "title": "The entry files target the starting point(s) to resolve the rest of the imported code.",
          "example": [
            "lib/index.ts"
          ],
          "default": [
            "index.{js,ts,tsx}",
            "src/index.{js,ts,tsx}"
          ],
          "$ref": "#/$defs/globPatterns"
        },
        "project": {
          "title": "The project files should contain all files to match against the files resolved from the entry files, including potentially unused files.",
          "example": [
            "lib/**/*.ts"
          ],
          "default": [
            "**/*.{js,ts,tsx}"
          ],
          "$ref": "#/$defs/globPatterns"
        },
        "paths": {
          "title": "",
          "example": {
            "~": [
              "."
            ]
          },
          "default": {},
          "$ref": "#/$defs/paths"
        },
        "ignore": {
          "title": "Files to exclude from the report (any issue type)",
          "example": [
            "**/fixtures/**",
            "mocks/**"
          ],
          "default": [],
          "$ref": "#/$defs/globPatterns"
        },
        "ignoreFiles": {
          "$ref": "#/$defs/ignoreFiles"
        },
        "ignoreBinaries": {
          "$ref": "#/$defs/ignoreBinaries"
        },
        "ignoreDependencies": {
          "$ref": "#/$defs/ignoreDependencies"
        },
        "ignoreMembers": {
          "$ref": "#/$defs/ignoreMembers"
        },
        "ignoreUnresolved": {
          "$ref": "#/$defs/ignoreUnresolved"
        },
        "includeEntryExports": {
          "$ref": "#/$defs/includeEntryExports"
        }
      }
    },
    "plugin": {
      "description": "Knip plugin configuration. See <https://knip.dev/explanations/plugins>",
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "$ref": "#/$defs/globPatterns"
        },
        {
          "type": "object",
          "properties": {
            "config": {
              "title": "The custom dependency resolver of this plugin is applied to the files listed here. Also see https://knip.dev/explanations/plugins",
              "examples": [
                ".eslintrc.json"
              ],
              "$ref": "#/$defs/globPatterns"
            },
            "entry": {
              "title": "The entry files target the starting point(s) to resolve its imported dependencies, like regular source code.",
              "examples": [
                "**/*.story.ts",
                "**/*.spec.ts"
              ],
              "$ref": "#/$defs/globPatterns"
            },
            "project": {
              "title": "The project files should contain all files to match against the files resolved from the entry files for this plugin, including potentially unused files.",
              "$ref": "#/$defs/globPatterns"
            }
          },
          "additionalProperties": false
        }
      ]
    },
