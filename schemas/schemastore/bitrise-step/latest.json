{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/bitrise-step/latest.json",
  "x-lintel": {
    "source": "https://www.schemastore.org/bitrise-step.json",
    "sourceSha256": "bc2b9b00f07f5a90875f95f06e77197e34c18c287dba4db6cdf44597521c9e4a",
    "fileMatch": [
      "step.yml"
    ],
    "parsers": [
      "yaml"
    ]
  },
  "id": "https://json.schemastore.org/bitrise-step.json",
  "$ref": "#/$defs/StepModel",
  "$defs": {
    "AptGetDepModel": {
      "properties": {
        "name": {
          "type": "string"
        },
        "bin_name": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "BashStepToolkitModel": {
      "properties": {
        "entry_file": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "BrewDepModel": {
      "properties": {
        "name": {
          "type": "string"
        },
        "bin_name": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "CheckOnlyDepModel": {
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "DependencyModel": {
      "properties": {
        "manager": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "DepsModel": {
      "properties": {
        "brew": {
          "items": {
            "$ref": "#/$defs/BrewDepModel"
          },
          "type": "array"
        },
        "apt_get": {
          "items": {
            "$ref": "#/$defs/AptGetDepModel"
          },
          "type": "array"
        },
        "check_only": {
          "items": {
            "$ref": "#/$defs/CheckOnlyDepModel"
          },
          "type": "array"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "ExecutableModel": {
      "properties": {
        "storage_uri": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "GoStepToolkitModel": {
      "required": [
        "package_name"
      ],
      "properties": {
        "package_name": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "StepModel": {
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "website": {
          "type": "string"
        },
        "source_code_url": {
          "type": "string"
        },
        "support_url": {
          "type": "string"
        },
        "published_at": {
          "type": "string",
          "format": "date-time"
        },
        "source": {
          "$ref": "#/$defs/StepSourceModel"
        },
        "asset_urls": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "type": "string"
            }
          }
        },
        "host_os_tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "project_type_tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "type_tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "dependencies": {
          "items": {
            "$ref": "#/$defs/DependencyModel"
          },
          "type": "array"
        },
        "toolkit": {
          "$ref": "#/$defs/StepToolkitModel"
        },
        "deps": {
          "$ref": "#/$defs/DepsModel"
        },
        "is_requires_admin_user": {
          "type": "boolean"
        },
        "is_always_run": {
          "type": "boolean"
        },
        "is_skippable": {
          "type": "boolean"
        },
        "run_if": {
          "type": "string"
        },
        "timeout": {
          "type": "integer"
        },
        "meta": {
          "type": "object",
          "patternProperties": {
            ".*": {
              "additionalProperties": true
            }
          }
        },
        "inputs": {
          "items": {
            "type": "object",
            "patternProperties": {
              ".*": {
                "additionalProperties": true
              }
            }
          },
          "type": "array"
        },
        "outputs": {
          "items": {
            "type": "object",
            "patternProperties": {
              ".*": {
                "additionalProperties": true
              }
            }
          },
          "type": "array"
        },
        "executables": {
          "description": "Platform-specific executable binaries",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/ExecutableModel"
          }
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "StepSourceModel": {
      "properties": {
        "git": {
          "type": "string"
        },
        "commit": {
          "type": "string"
        }
      },
      "type": "object",
      "additionalProperties": false
    },
    "StepToolkitModel": {
      "properties": {
        "bash": {
          "$ref": "#/$defs/BashStepToolkitModel"
        },
        "go": {
          "$ref": "#/$defs/GoStepToolkitModel"
        }
      },
      "type": "object",
      "additionalProperties": false
    }
  }
}
