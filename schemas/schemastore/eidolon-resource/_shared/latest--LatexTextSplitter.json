          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Separators to split on",
      "title": "Separators"
    },
    "is_separator_regex": {
      "default": false,
      "description": "Whether the separator is a regex",
      "title": "Is Separator Regex",
      "type": "boolean"
