      "type": "string"
    },
    "create_container_on_startup": {
      "default": false,
      "description": "If true, the container will be created on startup if not already present.",
      "title": "Create Container On Startup",
      "type": "boolean"
    },
    "pattern": {
      "default": "**",
      "title": "Pattern",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "_Reference": {
      "type": "object",
      "properties": {
        "implementation": {
          "title": "Implementation",
          "type": "string"
        }
      },
      "title": "_Reference",
      "additionalProperties": true
    }
  },
  "required": [
    "account_url",
    "container",
    "implementation"
  ],
  "reference_details": {
    "clz": "eidolon_ai_sdk.agent.doc_manager.loaders.azure_loader.AzureLoader",
    "groups": [
      "DocumentLoader"
    ],
    "name": "AzureLoader",
    "overrides": {}
  }
