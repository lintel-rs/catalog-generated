{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-logs-subscriptionfilter.json",
  "title": "AWSLogsSubscriptionFilterProperties",
  "description": "Subscription filters allow you to subscribe to a real-time stream of log events and have them delivered to a specific destination.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-logs>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-logs-subscriptionfilter.json",
    "sourceSha256": "dc3685f80a5fcafb693719e77eef021bfc812e5bce2a7a3ba9a303a4b5400174",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "FilterName": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The name of the filter generated by resource."
    },
    "DestinationArn": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The Amazon Resource Name (ARN) of the destination."
    },
    "FilterPattern": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The filtering expressions that restrict what gets delivered to the destination AWS resource."
    },
    "LogGroupName": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Existing log group that you want to associate with this filter."
    },
    "RoleArn": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The ARN of an IAM role that grants CloudWatch Logs permissions to deliver ingested log events to the destination stream. You don't need to provide the ARN when you are working with a logical destination for cross-account delivery."
    },
    "Distribution": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "Random",
            "ByLogStream"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The method used to distribute log data to the destination. By default, log data is grouped by log stream, but the grouping can be set to random for a more even distribution. This property is only applicable when the destination is an Amazon Kinesis stream."
    }
  },
  "typeName": "AWS::Logs::SubscriptionFilter",
  "additionalProperties": false,
  "primaryIdentifier": [
    "/properties/FilterName",
    "/properties/LogGroupName"
  ],
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-logs",
  "tagging": {
    "taggable": false,
    "tagOnCreate": false,
    "tagUpdatable": false,
    "cloudFormationSystemTags": false
  },
  "replacementStrategy": "delete_then_create",
  "createOnlyProperties": [
    "/properties/FilterName",
    "/properties/LogGroupName"
  ],
  "required": [
    "DestinationArn",
    "FilterPattern",
    "LogGroupName"
  ]
}
