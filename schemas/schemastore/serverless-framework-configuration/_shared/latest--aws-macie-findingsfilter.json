{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-macie-findingsfilter.json",
  "title": "AWSMacieFindingsFilterProperties",
  "description": "Macie FindingsFilter resource schema.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-macie.git>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-macie-findingsfilter.json",
    "sourceSha256": "0bc25ae284546f528c6a784ff27bc1e11f39b7de703bf11c4197a0df54923c10"
  },
  "type": "object",
  "properties": {
    "Name": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Findings filter name"
    },
    "Description": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Findings filter description"
    },
    "FindingCriteria": {
      "description": "Findings filter criteria.",
      "$ref": "#/$defs/FindingCriteria"
    },
    "Action": {
      "description": "Findings filter action.",
      "$ref": "#/$defs/FindingFilterAction"
    },
    "Position": {
      "description": "Findings filter position.",
      "type": "integer"
    }
  },
  "typeName": "AWS::Macie::FindingsFilter",
  "additionalIdentifiers": [
    [
      "/properties/Arn"
    ],
    [
      "/properties/Name"
    ]
  ],
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-macie.git",
  "additionalProperties": false,
  "primaryIdentifier": [
    "/properties/Id"
  ],
  "required": [
    "Name",
    "FindingCriteria"
  ],
  "$defs": {
    "CriterionAdditionalProperties": {
      "type": "object",
      "properties": {
        "gt": {
          "type": "integer",
          "format": "int64"
        },
        "gte": {
          "type": "integer",
          "format": "int64"
        },
        "lt": {
          "type": "integer",
          "format": "int64"
        },
        "lte": {
          "type": "integer",
          "format": "int64"
        },
        "eq": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "neq": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "title": "AWSMacieFindingsFilterCriterionAdditionalPropertiesDefinition",
      "additionalProperties": false
    },
    "Criterion": {
      "description": "Map of filter criteria.",
      "type": "object",
      "additionalProperties": false,
      "title": "AWSMacieFindingsFilterCriterionDefinition",
      "patternProperties": {
        "\\w": {
          "$ref": "#/$defs/CriterionAdditionalProperties"
        }
      }
    },
    "FindingCriteria": {
      "type": "object",
      "properties": {
        "Criterion": {
          "$ref": "#/$defs/Criterion"
        }
      },
      "title": "AWSMacieFindingsFilterFindingCriteriaDefinition",
      "additionalProperties": false
    },
    "FindingFilterAction": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ARCHIVE",
            "NOOP"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "title": "AWSMacieFindingsFilterFindingFilterActionDefinition"
    },
    "FindingsFilterListItem": {
      "description": "Returned by ListHandler representing filter name and ID.",
      "type": "object",
      "properties": {
        "Id": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        },
        "Name": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        }
      },
      "title": "AWSMacieFindingsFilterFindingsFilterListItemDefinition"
    }
  },
  "readOnlyProperties": [
    "/properties/Id",
    "/properties/Arn"
  ]
}
