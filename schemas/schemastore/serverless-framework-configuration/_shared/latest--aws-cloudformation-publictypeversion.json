{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-cloudformation-publictypeversion.json",
  "title": "AWSCloudFormationPublicTypeVersionProperties",
  "description": "Test and Publish a resource that has been registered in the CloudFormation Registry.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-cloudformation>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-cloudformation-publictypeversion.json",
    "sourceSha256": "ba05918d1b04afadf6f49cf3cd50133fd0d220d3e9308dd42c06d480b510d94d",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "Arn": {
      "oneOf": [
        {
          "pattern": "arn:aws[A-Za-z0-9-]{0,64}:cloudformation:[A-Za-z0-9-]{1,64}:[0-9]{12}:type/.+",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The Amazon Resource Number (ARN) of the extension."
    },
    "PublicVersionNumber": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 5,
          "maxLength": 64
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The version number of a public third-party extension"
    },
    "TypeName": {
      "oneOf": [
        {
          "pattern": "[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}(::MODULE){0,1}",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The name of the type being registered.\n\nWe recommend that type names adhere to the following pattern: company_or_organization::service::type."
    },
    "LogDeliveryBucket": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "A url to the S3 bucket where logs for the testType run will be available"
    },
    "Type": {
      "oneOf": [
        {
          "enum": [
            "RESOURCE",
            "MODULE",
            "HOOK"
          ],
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The kind of extension"
    }
  },
  "typeName": "AWS::CloudFormation::PublicTypeVersion",
  "additionalProperties": false,
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-cloudformation",
  "primaryIdentifier": [
    "/properties/PublicTypeArn"
  ],
  "oneOf": [
    {
      "required": [
        "TypeName",
        "Type"
      ]
    },
    {
      "required": [
        "Arn"
      ]
    }
  ],
  "readOnlyProperties": [
    "/properties/PublicTypeArn",
    "/properties/TypeVersionArn",
    "/properties/PublisherId"
  ],
  "createOnlyProperties": [
    "/properties/LogDeliveryBucket",
    "/properties/PublicVersionNumber",
    "/properties/TypeName",
    "/properties/Type",
    "/properties/Arn"
  ]
}
