{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-robomaker-simulationapplicationversion.json",
  "title": "AWSRoboMakerSimulationApplicationVersionProperties",
  "description": "AWS::RoboMaker::SimulationApplicationVersion resource creates an AWS RoboMaker SimulationApplicationVersion. This helps you control which code your simulation uses.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-robomaker-simulationapplicationversion.json",
    "sourceSha256": "a986849dab189514941229dceb8a8bdd515d5f5db272394488c3e731592836d7",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "Application": {
      "$ref": "#/$defs/Arn"
    },
    "CurrentRevisionId": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 40,
          "pattern": "[a-zA-Z0-9_.\\-]*"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The revision ID of robot application."
    }
  },
  "typeName": "AWS::RoboMaker::SimulationApplicationVersion",
  "taggable": false,
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "$defs": {
    "Arn": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "arn:[\\w+=/,.@-]+:[\\w+=/,.@-]+:[\\w+=/,.@-]*:[0-9]*:[\\w+=,.@-]+(/[\\w+=,.@-]+)*"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "title": "AWSRoboMakerSimulationApplicationVersionArnDefinition"
    }
  },
  "createOnlyProperties": [
    "/properties/Application",
    "/properties/CurrentRevisionId"
  ],
  "additionalProperties": false,
  "required": [
    "Application"
  ],
  "readOnlyProperties": [
    "/properties/ApplicationVersion",
    "/properties/Arn"
  ],
  "primaryIdentifier": [
    "/properties/Arn"
  ]
