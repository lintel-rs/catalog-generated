{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-globalaccelerator-listener.json",
  "title": "AWSGlobalAcceleratorListenerProperties",
  "description": "Resource Type definition for AWS::GlobalAccelerator::Listener. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-globalaccelerator>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-globalaccelerator-listener.json",
    "sourceSha256": "ab1c4ae665d6d3f6ef4b34317c55ac410a22cfd22b6e6ff33eb05ccc423c4784",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "AcceleratorArn": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The Amazon Resource Name (ARN) of the accelerator."
    },
    "PortRanges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PortRange"
      }
    },
    "Protocol": {
      "oneOf": [
        {
          "type": "string",
          "default": "TCP",
          "enum": [
            "TCP",
            "UDP"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The protocol for the listener."
    },
    "ClientAffinity": {
      "oneOf": [
        {
          "type": "string",
          "default": "NONE",
          "enum": [
            "NONE",
            "SOURCE_IP"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Client affinity lets you direct all requests from a user to the same endpoint."
    }
  },
  "typeName": "AWS::GlobalAccelerator::Listener",
  "additionalProperties": false,
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-globalaccelerator",
  "$defs": {
    "Port": {
      "description": "A network port number",
      "type": "integer",
      "minimum": 0,
      "maximum": 65535,
      "title": "AWSGlobalAcceleratorListenerPortDefinition"
    },
    "PortRange": {
      "description": "A port range to support for connections from  clients to your accelerator.",
      "type": "object",
      "properties": {
        "FromPort": {
          "$ref": "#/$defs/Port"
        },
        "ToPort": {
          "$ref": "#/$defs/Port"
        }
      },
      "required": [
        "FromPort",
        "ToPort"
      ],
      "additionalProperties": false,
      "title": "AWSGlobalAcceleratorListenerPortRangeDefinition"
    }
  },
  "primaryIdentifier": [
    "/properties/ListenerArn"
  ],
  "required": [
    "AcceleratorArn",
    "PortRanges",
    "Protocol"
  ],
  "createOnlyProperties": [
    "/properties/AcceleratorArn"
  ],
  "readOnlyProperties": [
    "/properties/ListenerArn"
  ]
}
