{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-datasync-locationfsxwindows.json",
  "title": "AWSDataSyncLocationFSxWindowsProperties",
  "description": "Resource schema for AWS::DataSync::LocationFSxWindows.. Source:- https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-datasync.git",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-datasync-locationfsxwindows.json",
