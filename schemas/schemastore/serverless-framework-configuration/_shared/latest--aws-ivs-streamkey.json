{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-ivs-streamkey.json",
  "title": "AWSIVSStreamKeyProperties",
  "description": "Resource Type definition for AWS::IVS::StreamKey. Source:- https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-ivs-streamkey.json",
    "sourceSha256": "eaa2d24c26bf4812ec0d3328ac28fef2958604d063d208a3f5a738f2b9fdea56",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "ChannelArn": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^arn:aws:ivs:[a-z0-9-]+:[0-9]+:channel/[a-zA-Z0-9-]+$"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Channel ARN for the stream."
    },
    "Tags": {
      "description": "A list of key-value pairs that contain metadata for the asset model.",
      "type": "array",
      "uniqueItems": true,
      "insertionOrder": false,
      "maxItems": 50,
      "items": {
        "$ref": "#/$defs/Tag"
      }
    }
  },
  "typeName": "AWS::IVS::StreamKey",
  "primaryIdentifier": [
    "/properties/Arn"
  ],
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "$defs": {
    "Tag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Key": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        },
        "Value": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "maxLength": 256
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        }
      },
      "required": [
        "Value",
        "Key"
      ],
      "title": "AWSIVSStreamKeyTagDefinition"
    }
  },
  "readOnlyProperties": [
    "/properties/Arn",
    "/properties/Value"
  ],
  "additionalProperties": false,
  "replacementStrategy": "delete_then_create",
  "required": [
    "ChannelArn"
  ],
  "createOnlyProperties": [
    "/properties/ChannelArn"
  ]
}
