        {
          "required": [
            "LogGroup"
          ]
        }
      ],
      "title": "AWSEvidentlyProjectDataDeliveryObjectDefinition",
      "additionalProperties": false
    },
    "S3Destination": {
      "type": "object",
      "properties": {
        "BucketName": {
          "oneOf": [
