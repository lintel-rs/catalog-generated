  "additionalProperties": false,
  "$defs": {
    "DataDeliveryObject": {
      "type": "object",
      "description": "Destinations for data.",
      "properties": {
        "S3": {
          "$ref": "#/$defs/S3Destination"
        },
        "LogGroup": {
          "oneOf": [
            {
              "type": "string",
