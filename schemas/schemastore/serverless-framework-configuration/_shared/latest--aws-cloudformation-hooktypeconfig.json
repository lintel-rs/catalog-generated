{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-cloudformation-hooktypeconfig.json",
  "title": "AWSCloudFormationHookTypeConfigProperties",
  "description": "Specifies the configuration data for a registered hook in CloudFormation Registry.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-cloudformation>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-cloudformation-hooktypeconfig.json",
    "sourceSha256": "5b297992cc81ddda6774ed48d725418594fa697f93949bb8684d24d292a6fc4a",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "TypeArn": {
      "oneOf": [
        {
          "pattern": "^arn:aws[A-Za-z0-9-]{0,64}:cloudformation:[A-Za-z0-9-]{1,64}:([0-9]{12})?:type/hook/.+$",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The Amazon Resource Name (ARN) of the type without version number."
    },
    "TypeName": {
      "oneOf": [
        {
          "pattern": "^[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}::[A-Za-z0-9]{2,64}$",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The name of the type being registered.\n\nWe recommend that type names adhere to the following pattern: company_or_organization::service::type."
    },
    "Configuration": {
      "oneOf": [
        {
          "pattern": "[\\s\\S]+",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The configuration data for the extension, in this account and region."
    },
    "ConfigurationAlias": {
      "oneOf": [
        {
          "pattern": "^[a-zA-Z0-9]{1,256}$",
          "default": "default",
          "enum": [
            "default"
          ],
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "An alias by which to refer to this extension configuration data."
    }
  },
  "typeName": "AWS::CloudFormation::HookTypeConfig",
  "additionalProperties": false,
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-cloudformation",
  "primaryIdentifier": [
    "/properties/ConfigurationArn"
  ],
  "oneOf": [
    {
      "required": [
        "TypeArn",
        "Configuration"
      ]
    },
    {
      "required": [
        "TypeName",
        "Configuration"
      ]
    }
  ],
  "readOnlyProperties": [
    "/properties/ConfigurationArn"
  ],
  "createOnlyProperties": [
    "/properties/ConfigurationAlias"
  ]
}
