        "KeyEncipherment": {
          "type": "boolean",
          "default": false
        },
        "DataEncipherment": {
          "type": "boolean",
          "default": false
        },
        "KeyAgreement": {
          "type": "boolean",
          "default": false
        },
        "KeyCertSign": {
          "type": "boolean",
          "default": false
        },
        "CRLSign": {
          "type": "boolean",
          "default": false
        },
        "EncipherOnly": {
          "type": "boolean",
          "default": false
        },
        "DecipherOnly": {
          "type": "boolean",
          "default": false
        }
      },
