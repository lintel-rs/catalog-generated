  "primaryIdentifier": [
    "/properties/Arn",
    "/properties/CertificateAuthorityArn"
  ],
  "sourceUrl": "https://docs.aws.amazon.com/AWSCloudFormation/latest/UserGuide/AWS_ACMPCA.html",
