{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-iot-authorizer.json",
  "title": "AWSIoTAuthorizerProperties",
  "description": "Creates an authorizer.. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-iot-authorizer.json",
    "sourceSha256": "5729982c89f674200d1b10fa5fa842b296d79a20d097cba3fd02fbd31efd2909"
  },
  "type": "object",
  "properties": {
    "AuthorizerFunctionArn": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ]
    },
    "AuthorizerName": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "[\\w=,@-]+",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ]
    },
    "SigningDisabled": {
      "type": "boolean"
    },
    "Status": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "ACTIVE",
            "INACTIVE"
          ]
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ]
    },
    "TokenKeyName": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ]
    },
    "TokenSigningPublicKeys": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "[a-zA-Z0-9:_-]+": {
          "type": "string",
          "maxLength": 5120
        }
      }
    },
    "EnableCachingForHttp": {
      "type": "boolean"
    },
    "Tags": {
      "type": "array",
      "insertionOrder": true,
      "items": {
        "$ref": "#/$defs/Tag"
      }
    }
  },
  "typeName": "AWS::IoT::Authorizer",
  "primaryIdentifier": [
    "/properties/AuthorizerName"
  ],
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-rpdk.git",
  "additionalProperties": false,
  "readOnlyProperties": [
    "/properties/Arn"
  ],
  "tagging": {
    "taggable": true,
    "tagOnCreate": true,
    "tagUpdatable": true,
    "cloudFormationSystemTags": true,
    "tagProperty": "/properties/Tags"
  },
  "$defs": {
    "Tag": {
      "type": "object",
      "properties": {
        "Key": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        },
        "Value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ]
        }
      },
      "title": "AWSIoTAuthorizerTagDefinition",
      "required": [
        "Key",
        "Value"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "AuthorizerFunctionArn"
  ],
  "createOnlyProperties": [
    "/properties/SigningDisabled",
    "/properties/AuthorizerName"
  ]
}
