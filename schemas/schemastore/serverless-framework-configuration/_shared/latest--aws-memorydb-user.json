{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--aws-memorydb-user.json",
  "title": "AWSMemoryDBUserProperties",
  "description": "Resource Type definition for AWS::MemoryDB::User. Source:- <https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-memorydb>",
  "x-lintel": {
    "source": "https://raw.githubusercontent.com/lalcebo/json-schema/master/serverless/resources/cloudformation-modified/aws-memorydb-user.json",
    "sourceSha256": "6212aea20572071c5ed7d865c411a397355f40a523fc5b5c004f69333403d0d4",
    "invalid": true
  },
  "type": "object",
  "properties": {
    "UserName": {
      "oneOf": [
        {
          "pattern": "[a-z][a-z0-9\\\\-]*",
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "The name of the user."
    },
    "AccessString": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
        }
      ],
      "description": "Access permissions string used for this user account."
    },
    "AuthenticationMode": {
      "type": "object",
      "properties": {
        "Type": {
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "password",
                "iam"
              ]
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ],
          "description": "Type of authentication strategy for this user."
        },
        "Passwords": {
          "type": "array",
          "$comment": "List of passwords.",
          "uniqueItems": true,
          "insertionOrder": true,
          "maxItems": 2,
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "Passwords used for this user account. You can create up to two passwords for each user."
        }
      },
      "additionalProperties": false
    },
    "Tags": {
      "description": "An array of key-value pairs to apply to this user.",
      "type": "array",
      "maxItems": 50,
      "uniqueItems": true,
      "insertionOrder": false,
      "items": {
        "$ref": "#/$defs/Tag"
      }
    }
  },
  "typeName": "AWS::MemoryDB::User",
  "primaryIdentifier": [
    "/properties/UserName"
  ],
  "sourceUrl": "https://github.com/aws-cloudformation/aws-cloudformation-resource-providers-memorydb",
  "taggable": true,
  "$defs": {
    "Tag": {
      "description": "A key-value pair to associate with a resource.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "Key": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(?!aws:)[a-zA-Z0-9 _\\.\\/=+:\\-@]*$",
              "minLength": 1,
              "maxLength": 128
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ],
          "description": "The key name of the tag. You can specify a value that is 1 to 128 Unicode characters in length and cannot be prefixed with 'aws:'. You can use any of the following characters: the set of Unicode letters, digits, whitespace, _, ., /, =, +, and -."
        },
        "Value": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[a-zA-Z0-9 _\\.\\/=+:\\-@]*$",
              "minLength": 0,
              "maxLength": 256
            },
            {
              "$ref": "https://catalog.lintel.tools/schemas/schemastore/serverless-framework-configuration/_shared/latest--cf.functions.json#/Aws_CF_FunctionString"
            }
          ],
          "description": "The value for the tag. You can specify a value that is 0 to 256 Unicode characters in length. You can use any of the following characters: the set of Unicode letters, digits, whitespace, _, ., /, =, +, and -."
        }
      },
      "required": [
        "Key"
      ],
      "title": "AWSMemoryDBUserTagDefinition"
    }
  },
  "writeOnlyProperties": [
    "/properties/AuthenticationMode",
    "/properties/AccessString"
  ],
  "additionalProperties": false,
  "required": [
    "UserName"
  ],
  "readOnlyProperties": [
    "/properties/Status",
    "/properties/Arn"
  ],
  "createOnlyProperties": [
    "/properties/UserName"
  ]
}
