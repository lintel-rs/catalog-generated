        },
        "Exclude": {
          "$ref": "#/$defs/BucketsAndRegions"
        },
        "AwsOrg": {
          "$ref": "#/$defs/AwsOrg"
        },
        "AccountLevel": {
          "$ref": "#/$defs/AccountLevel"
        },
        "DataExport": {
          "$ref": "#/$defs/DataExport"
